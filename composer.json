{
    "name": "nahook/nahook-php",
    "description": "Official PHP SDK for the Nahook webhook platform",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0",
        "ramsey/uuid": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Nahook\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nahook\\Tests\\": "tests/"
        }
    }
}
